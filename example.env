# Supabase project (printed by `supabase projects create` or `supabase status`)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Lock the app to your GitHub account's primary email. The auth callback and
# proxy both reject any other email; the DB also enforces this via RLS using
# the `app.allowed_email` Postgres setting (see supabase/seed.sql).
# NOTE: must match your GitHub primary verified email — make sure
# https://github.com/settings/emails has this email listed and verified.
ALLOWED_EMAIL=harsh.m@simformsolutions.com

# Used by `supabase config push` to wire GitHub OAuth without dashboard clicks.
# Create an OAuth app at https://github.com/settings/developers
#   Homepage URL:        http://localhost:3000   (or your Vercel URL)
#   Authorization callback URL: https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
